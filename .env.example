# =============================================================================
# PHARMACY ERP - ENVIRONMENT VARIABLES EXAMPLE
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# =============================================================================

# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------
NODE_ENV=development
APP_NAME="Pharmacy ERP"
APP_VERSION=1.0.0
FRONTEND_PORT=3000
BACKEND_PORT=4000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000

# -----------------------------------------------------------------------------
# DATABASE (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=pharmacy_erp
POSTGRES_USER=pharmacy_user
POSTGRES_PASSWORD=your_secure_postgres_password_here
DATABASE_URL="postgresql://pharmacy_user:your_secure_postgres_password_here@localhost:5432/pharmacy_erp?schema=public"
# For connection pooling (PgBouncer / Prisma Accelerate)
DATABASE_DIRECT_URL="postgresql://pharmacy_user:your_secure_postgres_password_here@localhost:5432/pharmacy_erp?schema=public"
# Max connections in the pool
DATABASE_POOL_SIZE=10
DATABASE_POOL_TIMEOUT=30

# -----------------------------------------------------------------------------
# REDIS CACHE
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_secure_redis_password_here
REDIS_URL="redis://:your_secure_redis_password_here@localhost:6379"
REDIS_TTL_DEFAULT=3600
REDIS_TTL_SESSION=86400
REDIS_TTL_OTP=300

# -----------------------------------------------------------------------------
# JWT AUTHENTICATION
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 64
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long_here
JWT_REFRESH_SECRET=your_super_secret_refresh_jwt_key_minimum_32_characters_long_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=pharmacy-erp
JWT_AUDIENCE=pharmacy-erp-users

# -----------------------------------------------------------------------------
# TWO-FACTOR AUTHENTICATION (2FA)
# -----------------------------------------------------------------------------
TOTP_SERVICE_NAME="Pharmacy ERP"
TOTP_ISSUER="PharmacyERP"
TOTP_WINDOW=1

# -----------------------------------------------------------------------------
# AWS S3 (File Storage - Prescriptions, Reports)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGION=ap-south-1
AWS_S3_BUCKET_NAME=pharmacy-erp-files
AWS_S3_BUCKET_REGION=ap-south-1
AWS_CLOUDFRONT_URL=https://your-cloudfront-distribution.cloudfront.net
# Presigned URL expiry in seconds (default: 1 hour)
AWS_S3_PRESIGNED_URL_EXPIRY=3600

# -----------------------------------------------------------------------------
# EMAIL (Gmail SMTP / AWS SES)
# -----------------------------------------------------------------------------
MAIL_PROVIDER=gmail
GMAIL_USER=your_gmail_address@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password_16_chars
GMAIL_FROM_NAME="Pharmacy ERP"
GMAIL_FROM_EMAIL=noreply@yourpharmacy.com
# For AWS SES (alternative)
SES_REGION=ap-south-1
SES_FROM_EMAIL=noreply@yourpharmacy.com

# -----------------------------------------------------------------------------
# WHATSAPP BUSINESS API
# -----------------------------------------------------------------------------
WHATSAPP_PROVIDER=meta
# Meta (Facebook) WhatsApp Business API
WHATSAPP_META_ACCESS_TOKEN=your_meta_whatsapp_access_token_here
WHATSAPP_META_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here
WHATSAPP_META_BUSINESS_ACCOUNT_ID=your_whatsapp_business_account_id_here
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token_here
# Twilio WhatsApp (alternative)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# 2Factor / MSG91 (India)
MSG91_AUTH_KEY=your_msg91_auth_key_here
MSG91_SENDER_ID=PHARMERP
MSG91_WHATSAPP_INTEGRATED_NUMBER=your_msg91_whatsapp_number

# -----------------------------------------------------------------------------
# SMS (for OTP, alerts)
# -----------------------------------------------------------------------------
SMS_PROVIDER=msg91
MSG91_SMS_AUTH_KEY=your_msg91_sms_auth_key_here
MSG91_SMS_SENDER_ID=PHARMERP
MSG91_SMS_ROUTE=4
# Twilio SMS (alternative)
TWILIO_SMS_FROM=+1234567890

# -----------------------------------------------------------------------------
# OPENAI API (AI-powered features)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=2048
OPENAI_TEMPERATURE=0.3
# For drug interaction checking, prescription OCR, etc.
OPENAI_VISION_MODEL=gpt-4o

# -----------------------------------------------------------------------------
# PAYMENT GATEWAY
# -----------------------------------------------------------------------------
# Razorpay (India)
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here
# Stripe (International)
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# -----------------------------------------------------------------------------
# SECURITY
# -----------------------------------------------------------------------------
# Rate limiting (requests per window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX=10
# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
# Encryption key for sensitive data at rest (AES-256)
ENCRYPTION_KEY=your_32_byte_encryption_key_in_hex_here_64_chars
ENCRYPTION_IV_LENGTH=16

# -----------------------------------------------------------------------------
# FILE UPLOAD
# -----------------------------------------------------------------------------
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,application/pdf
UPLOAD_DIR=./uploads
# Local storage path (used if S3 not configured)
LOCAL_STORAGE_PATH=./uploads

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_DIR=./logs
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d
LOG_COLORIZE=true

# -----------------------------------------------------------------------------
# NEXT.JS FRONTEND
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Pharmacy ERP"
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_id_here
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# -----------------------------------------------------------------------------
# GST / INDIA SPECIFIC
# -----------------------------------------------------------------------------
GST_API_URL=https://api.gst.gov.in
GST_API_KEY=your_gst_api_key_here
DEFAULT_GST_RATES=0,5,12,18,28

# -----------------------------------------------------------------------------
# DRUG DATABASE API
# -----------------------------------------------------------------------------
DRUG_DB_API_URL=https://api.fda.gov/drug
DRUG_DB_API_KEY=your_fda_api_key_here
# OpenFDA for drug interaction checking
OPEN_FDA_API_KEY=your_openfda_api_key_here
