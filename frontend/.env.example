# ── Frontend environment (Next.js) ───────────────────────────────────────────
# Copy this file to `.env.local` and adjust as needed:
#   cp frontend/.env.example frontend/.env.local
#
# All NEXT_PUBLIC_* values are exposed to the browser — never put secrets here.

# Base URL of the backend API. The Next.js rewrite in next.config.js proxies
# `/api/*` to this origin, so the browser only ever talks to the frontend.
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Public URL the app is served from (used for serverActions allowed origins).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Display name shown in the UI.
NEXT_PUBLIC_APP_NAME=Pharmacy ERP

# Alternative to NEXT_PUBLIC_API_URL: if set (and NEXT_PUBLIC_API_URL is not),
# the dev rewrite targets http://localhost:<BACKEND_PORT>/api instead.
# BACKEND_PORT=4000
